# ─── Data Sources ──────────────────────────────────────────────────────────
PROMETHEUS_URL=http://10.0.11.69:9090
GRAFANA_URL=http://10.0.11.70:3000
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# InfluxDB — queried directly for OPNsense WAN traffic
INFLUXDB_URL=http://10.0.11.74:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=galaxy
INFLUXDB_BUCKET=opnsense
# WAN interface name on both OPNsense firewalls (em0 verified for halt + stop)
WAN_INTERFACE=em0
# Grafana datasource UID (kept for reference, not used for WAN queries)
INFLUXDB_DATASOURCE_UID=P951FEA4DE68E13C5

# LibreNMS (optional — not yet wired up)
LIBRENMS_URL=http://10.0.19.97:8000
LIBRENMS_TOKEN=

# ─── Host Config ───────────────────────────────────────────────────────────
# Comma-separated list of Linux node hostnames (must match Prometheus instance labels)
LINUX_HOSTS=containy,voyager,knox,dilithium,amp-server

# Comma-separated list of OPNsense firewall instance labels from Prometheus
FW_HOSTS=fort-opnsense,hawk-opnsense

# ─── Authentication ─────────────────────────────────────────────────────────
# AUTH_ENABLED=true requires one of:
#   - API_TOKEN set: clients send "Authorization: Bearer <your-token>"
#   - API_TOKEN unset: requires OAuth2 proxy (Authentik/oauth2-proxy) setting X-Forwarded-User
AUTH_ENABLED=false
API_TOKEN=

# ─── Kiosk timing ──────────────────────────────────────────────────────────
# Milliseconds per slide (slide 0 = hosts, 1 = performance, 2 = alerts)
KIOSK_SLIDE_DURATIONS=15000,12000,12000

# ─── LLM (Ask NOLA) ─────────────────────────────────────────────────────────
# Primary: Ollama (see deploy/containy/docker-compose.ollama.yml for setup)
OLLAMA_URL=http://10.0.11.25:11434
OLLAMA_MODEL=llama3.2:3b
# Fallback: Claude API if Ollama is unreachable. Leave blank to use Ollama-only.
ANTHROPIC_API_KEY=
# Set to false to disable Claude fallback entirely
LLM_FALLBACK=true

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3000
TZ=America/Los_Angeles
NODE_ENV=production
