# ─────────────────────────────────────────────
# NOLA — Non-Organic Lab Assistant
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Postgres ──────────────────────────────────
POSTGRES_DB=nola
POSTGRES_USER=nola
POSTGRES_PASSWORD=changeme_strong_password

# ── n8n ───────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32

# Public hostname where n8n is reachable
N8N_HOST=localhost
N8N_PROTOCOL=http

# Full base URL for webhooks (must be reachable from Discord bot and VAPI)
# Example: https://n8n.yourdomain.com  or  http://localhost:5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# ── AI Model ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for NOLA
NOLA_MODEL=claude-sonnet-4-6

# NOLA system prompt — customize to your lab name and personality
NOLA_SYSTEM_PROMPT=You are NOLA, an AI assistant managing a homelab. You have access to tools to check system status, query metrics, run commands on hosts, and send alerts. Be concise and accurate. When reporting metrics, always include the host name. Confirm before executing destructive commands.

# ── Discord ───────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token

# Right-click the channel in Discord (Developer Mode on) → Copy Channel ID
DISCORD_CHANNEL_ID=000000000000000000

# Webhook URL for NOLA to post proactive alerts into Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# Webhook URL the Discord bot sends messages to (internal Docker network)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/nola

# ── Infrastructure ────────────────────────────
# Netdata API base URLs — comma-separated name:url pairs (no trailing slash)
# Replace with your host labels and URLs. Hostnames resolve if split DNS is
# configured; otherwise use IPs.
# Hawk House hosts use .galaxy domain, Fort hosts use .universe domain.
NETDATA_HOSTS=hawk:http://hawk.galaxy:19999,fort:http://fort.universe:19999

# Prometheus base URL
PROMETHEUS_URL=http://prometheus.galaxy:9090

# apcupsd NIS host and port — one per firewall
# stop = Hawk House firewall (.galaxy), halt = Fort firewall (.universe)
UPS_HOST=stop.galaxy
UPS_HOST_FORT=halt.universe
UPS_PORT=3551

# SSH hosts NOLA is allowed to run commands on (comma-separated labels)
# These map to SSH_HOST_<LABEL> vars below
SSH_ALLOWED_HOSTS=hawk,knox

# SSH connection details per host — add a block per host in SSH_ALLOWED_HOSTS
SSH_HOST_HAWK=hawk.galaxy
SSH_USER_HAWK=gadget
SSH_KEY_HAWK=/run/secrets/ssh_key_hawk

SSH_HOST_KNOX=knox.universe
SSH_USER_KNOX=gadget
SSH_KEY_KNOX=/run/secrets/ssh_key_knox

# ── Ollama (optional — local AI for summaries) ─
# containy = Hawk House DMZ  |  knox = Fort DMZ
OLLAMA_URL_CONTAINY=http://containy.galaxy:11434
OLLAMA_URL_KNOX=http://knox.universe:11434
OLLAMA_MODEL=llama3.2:3b

# ── Loki log queries ──────────────────────────
LOKI_URL=http://loki.galaxy:3100

# ── ntopng traffic stats ──────────────────────
NTOPNG_URL=http://ntopng.universe:3005
# Generate at: ntopng → Admin → Users → your user → API token
NTOPNG_TOKEN=your_ntopng_api_token

# ── NetBox inventory ──────────────────────────
NETBOX_URL=https://netbox.galaxy.rip
# Generate at: NetBox → Admin → API Tokens (v4 format: nbt_...)
NETBOX_TOKEN=nbt_your_token_here

# ── VAPI (optional — voice calls) ─────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# n8n webhook path VAPI sends tool calls to
N8N_VAPI_TOOL_URL=http://n8n:5678/webhook/nola-vapi-tool

# Phone number to call for critical alerts (E.164 format)
ALERT_PHONE_NUMBER=+15555555555

# ── ElevenLabs (optional — voice for VAPI) ────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Timezone ──────────────────────────────────
TIMEZONE=America/Los_Angeles
